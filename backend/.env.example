DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,backend
DJANGO_TIME_ZONE=UTC
# Database defaults to SQLite outside Docker.
# Docker Compose injects PostgreSQL settings from the root .env file.
# thread: simple async simulation for local use
# sync: deterministic mode mainly for tests
# celery: requires Redis and a running worker
CLAIMS_PROCESSING_MODE=thread
CLAIMS_PROCESSING_DELAY_SECONDS=1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
