COMPOSE_PROJECT_NAME=pir
BACKEND_PORT=8000
FRONTEND_PORT=5173
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_DB=pir
POSTGRES_USER=pir
POSTGRES_PASSWORD=pir
REDIS_IMAGE=redis:7-alpine
BACKEND_ENV_FILE=./backend/.env
WORKER_ENV_FILE=./backend/.env.worker
BACKEND_COMMAND=python manage.py migrate && python manage.py runserver 0.0.0.0:8000
WORKER_COMMAND=celery -A config worker -l info
FRONTEND_COMMAND=npm run dev -- --host 0.0.0.0 --port 5173
FRONTEND_PROXY_TARGET=http://backend:8000
